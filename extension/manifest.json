{
  "manifest_version": 3,
  "name": "break-pharma connect",
  "version": "1.2.4",
  "description": "Envoie vos factures/avoirs Digipharmacie vers break-pharma.fr, en un clic, depuis votre session.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://app.digipharmacie.fr/*",
    "https://pharmacie-remises.onrender.com/*",
    "https://api.break-pharma.fr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "break-pharma connect",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.digipharmacie.fr/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "break-pharma-connect@break-pharma.fr",
      "strict_min_version": "115.0"
    }
  }
}